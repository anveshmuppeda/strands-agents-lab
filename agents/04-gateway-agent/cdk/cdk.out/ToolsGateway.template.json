        "InlinePayload": [
         {
          "Description": "Get details about an AWS subnet — CIDR, AZ, public/private, available IPs.",
          "InputSchema": {
           "Properties": {
            "subnet_id": {
             "Description": "AWS Subnet ID (e.g., 'subnet-0abc123')",
             "Type": "string"
